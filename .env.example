# Server
SERVER_PORT=8080
GIN_MODE=debug  # debug | release
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://another-origin.com

# ── Database ─────────────────────────────────────────────────
# Option A: Single URL (Neon / Render / Railway / Supabase)
# DATABASE_URL=postgres://user:password@ep-xyz.region.aws.neon.tech/neondb?sslmode=require

# Option B: Individual params (local / Docker Compose)
DB_HOST=localhost
DB_PORT=5432
DB_USER=jambotails
DB_PASSWORD=jambotails_secret
DB_NAME=jambotails
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=5

# ── Redis ─────────────────────────────────────────────────────
# Option A: Single URL (Render Redis / Upstash)
# REDIS_URL=redis://default:password@host:6379

# Option B: Individual params
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=debug  # debug | info | warn | error
